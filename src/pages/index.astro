---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArchiveCard from "../components/ArchiveCard.astro";
import { archives, categories, years } from "../data/archives.js";
---
<BaseLayout title="Mathematics Archive · BSEd">

  <!-- ── Hero header ──────────────────────────────────────────────────── -->
  <header class="hero">
    <div class="hero__eyebrow">
      <span class="hero__rule-line"></span>
      <span class="hero__eyebrow-text">Bachelor of Secondary Education</span>
      <span class="hero__rule-line"></span>
    </div>
    <h1 class="hero__title">Mathematics<br /><em>Archive Project</em></h1>
    <p class="hero__sub">
      A curated repository of academic resources, reference materials, and pedagogical guides
      spanning the full four-year BSEd Mathematics curriculum.
    </p>

    <button class="hero__team-btn" id="open-team-modal" type="button">
      <svg class="hero__team-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5.356-3.712M9 20H4v-2a4 4 0 015.356-3.712M15 7a4 4 0 11-8 0 4 4 0 018 0zm6 4a3 3 0 11-6 0 3 3 0 016 0zm-18 0a3 3 0 116 0 3 3 0 01-6 0z"/>
      </svg>
      Meet the Team
    </button>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-num">{archives.length}</span>
        <span class="hero__stat-label">Resources</span>
      </div>
      <div class="hero__stat-divider">◆</div>
      <div class="hero__stat">
        <span class="hero__stat-num">4</span>
        <span class="hero__stat-label">Year Levels</span>
      </div>
      <div class="hero__stat-divider">◆</div>
      <div class="hero__stat">
        <span class="hero__stat-num">4</span>
        <span class="hero__stat-label">Disciplines</span>
      </div>
    </div>
  </header>

  <!-- ── Ornamental divider ────────────────────────────────────────────── -->
  <div class="divider" aria-hidden="true">
    <span class="divider__line"></span>
    <span class="divider__ornament">— § —</span>
    <span class="divider__line"></span>
  </div>

  <!-- ── Filter panel ──────────────────────────────────────────────────── -->
  <section class="filter-panel" aria-label="Filter resources">
    <div class="filter-panel__header">
      <h2 class="filter-panel__title">Browse the Collection</h2>
      <span class="results-count" id="results-count">{archives.length} entries</span>
    </div>

    <!-- Search bar -->
    <div class="search-wrap">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="Search by title or topic…"
        autocomplete="off"
        spellcheck="false"
      />
      <button class="search-clear" id="search-clear" aria-label="Clear search" style="display:none;">✕</button>
    </div>

    <div class="filter-grid">
      <!-- Year Level -->
      <div class="filter-group">
        <span class="filter-label">
          <span class="filter-label__icon">◈</span>
          Year Level
        </span>
        <!-- Desktop: chips -->
        <div class="filter-chips" id="year-filters">
          {years.map((y) => (
            <button
              class={`chip${y.id === "all" ? " chip--active" : ""}`}
              data-filter-year={y.id}
            >
              {y.label}
            </button>
          ))}
        </div>
        <!-- Mobile: native select -->
        <div class="filter-select-wrap">
          <select id="year-select" class="filter-select" aria-label="Filter by year level">
            {years.map((y) => (
              <option value={y.id}>{y.label}</option>
            ))}
          </select>
          <span class="filter-select__arrow" aria-hidden="true">&#9662;</span>
        </div>
      </div>

      <!-- Discipline -->
      <div class="filter-group">
        <span class="filter-label">
          <span class="filter-label__icon">◈</span>
          Discipline
        </span>
        <!-- Desktop: chips -->
        <div class="filter-chips" id="category-filters">
          {categories.map((c) => (
            <button
              class={`chip${c.id === "all" ? " chip--active" : ""}`}
              data-filter-cat={c.id}
            >
              {c.label}
            </button>
          ))}
        </div>
        <!-- Mobile: native select -->
        <div class="filter-select-wrap">
          <select id="cat-select" class="filter-select" aria-label="Filter by discipline">
            {categories.map((c) => (
              <option value={c.id}>{c.label}</option>
            ))}
          </select>
          <span class="filter-select__arrow" aria-hidden="true">&#9662;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Card grid ─────────────────────────────────────────────────────── -->
  <section class="grid" id="archive-grid" aria-label="Archive entries">
    {archives.map((item) => (
      <div
        class="card-wrapper"
        data-year={item.year}
        data-category={item.category}
        data-search={`${item.title} ${item.description}`.toLowerCase()}
      >
        <ArchiveCard {...item} />
      </div>
    ))}
  </section>

  <p class="empty-state" id="empty-state" style="display:none;">
    <span class="empty-state__icon">∅</span><br />
    No entries found for the selected filters.
  </p>

  <!-- ── Contact divider ─────────────────────────────────────────────── -->
  <div class="divider" aria-hidden="true" style="margin-top: 4rem;">
    <span class="divider__line"></span>
    <span class="divider__ornament">— § —</span>
    <span class="divider__line"></span>
  </div>

  <!-- ── Messenger CTA ─────────────────────────────────────────────────── -->
  <div class="contact-cta">
    <div class="contact-cta__text">
      <span class="contact-cta__eyebrow">Have a question or suggestion?</span>
      <p class="contact-cta__desc">Reach out through Messenger and we'll get back to you.</p>
    </div>
    <a
      href="https://m.me/"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-cta__btn"
    >
      <svg class="contact-cta__btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.929 1.458 5.544 3.742 7.255V22l3.405-1.869c.909.252 1.871.387 2.853.387 5.523 0 10-4.145 10-9.275C22 6.145 17.523 2 12 2zm1.008 12.487l-2.548-2.718-4.972 2.718 5.473-5.808 2.609 2.718 4.91-2.718-5.472 5.808z"/>
      </svg>
      Message Us on Messenger
    </a>
  </div>

  <!-- ── Team Modal ───────────────────────────────────────────────────────── -->
  <div class="team-modal-overlay" id="team-modal" role="dialog" aria-modal="true" aria-label="Meet the Team" style="display:none;">
    <div class="team-modal">
      <div class="team-modal__header">
        <div class="team-modal__header-left">
          <span class="team-modal__eyebrow">&#10022; The People Behind It &#10022;</span>
          <h2 class="team-modal__title">Meet the <em>Team</em></h2>
        </div>
        <button class="team-modal__close" id="close-team-modal" aria-label="Close">&#x2715;</button>
      </div>
      <div class="team-modal__rule"></div>
      <div class="team-modal__grid" id="team-grid">
        <!-- Cards injected by JS -->
      </div>
    </div>
  </div>

</BaseLayout>

<script>
  const yearBtns   = document.querySelectorAll("[data-filter-year]");
  const catBtns    = document.querySelectorAll("[data-filter-cat]");
  const yearSelect = document.getElementById("year-select");
  const catSelect  = document.getElementById("cat-select");
  const allCards   = Array.from(document.querySelectorAll(".card-wrapper"));
  const countEl    = document.getElementById("results-count");
  const emptyEl    = document.getElementById("empty-state");
  const searchEl   = document.getElementById("search-input");
  const clearBtn   = document.getElementById("search-clear");

  let activeYear  = "all";
  let activeCat   = "all";
  let searchQuery = "";

  function applyFilters() {
    let visible = 0;
    allCards.forEach((c) => {
      const yearOk   = activeYear === "all" || c.dataset.year === activeYear;
      const catOk    = activeCat  === "all" || c.dataset.category === activeCat;
      const searchOk = searchQuery === "" || c.dataset.search.includes(searchQuery);
      const show = yearOk && catOk && searchOk;
      c.style.display = show ? "" : "none";
      if (show) visible++;
    });
    countEl.textContent = `${visible} entr${visible !== 1 ? "ies" : "y"}`;
    emptyEl.style.display = visible === 0 ? "block" : "none";
  }

  // ── Desktop chip buttons ──────────────────────────────────────────────────
  yearBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      yearBtns.forEach((b) => b.classList.remove("chip--active"));
      btn.classList.add("chip--active");
      activeYear = btn.dataset.filterYear;
      if (yearSelect) yearSelect.value = activeYear;
      applyFilters();
    });
  });

  catBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      catBtns.forEach((b) => b.classList.remove("chip--active"));
      btn.classList.add("chip--active");
      activeCat = btn.dataset.filterCat;
      if (catSelect) catSelect.value = activeCat;
      applyFilters();
    });
  });

  // ── Mobile select dropdowns ───────────────────────────────────────────────
  if (yearSelect) {
    yearSelect.addEventListener("change", () => {
      activeYear = yearSelect.value;
      yearBtns.forEach((b) => {
        b.classList.toggle("chip--active", b.dataset.filterYear === activeYear);
      });
      applyFilters();
    });
  }

  if (catSelect) {
    catSelect.addEventListener("change", () => {
      activeCat = catSelect.value;
      catBtns.forEach((b) => {
        b.classList.toggle("chip--active", b.dataset.filterCat === activeCat);
      });
      applyFilters();
    });
  }

  // ── Search ────────────────────────────────────────────────────────────────
  searchEl.addEventListener("input", () => {
    searchQuery = searchEl.value.trim().toLowerCase();
    clearBtn.style.display = searchQuery ? "flex" : "none";
    applyFilters();
  });

  clearBtn.addEventListener("click", () => {
    searchEl.value = "";
    searchQuery = "";
    clearBtn.style.display = "none";
    searchEl.focus();
    applyFilters();
  });

  applyFilters();
</script>

<style>
/* ── Hero ────────────────────────────────────────────────────────────────── */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;          /* center horizontally */
  justify-content: center;
  text-align: center;
  padding: 4rem 1.5rem;
  gap: 1.0rem;                 /* consistent vertical spacing */
}
.hero__eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.hero__rule-line {
  flex: 1;
  max-width: 80px;
  height: 1px;
  background: var(--gold);
  opacity: 0.5;
}
.hero__eyebrow-text {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
}
.hero__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 700;
  color: var(--navy);
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -0.01em;
}
.hero__title em {
  font-style: italic;
  color: var(--gold);
}
.hero__sub {
  font-family: 'EB Garamond', serif;
  font-size: 1.1rem;
  color: var(--ink-mid);
  line-height: 1.75;
  max-width: 560px;
  margin: 0 auto 2rem;
}
.hero__stats {
  display: inline-flex;
  align-items: center;
  gap: 1.5rem;
  border: 1px solid var(--border);
  background: var(--paper);
  padding: 0.9rem 2.5rem;
  border-top: 2px solid var(--gold);
  box-shadow: 0 2px 12px var(--shadow);
  flex-wrap: wrap;
  justify-content: center;
}
.hero__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.1rem;
}
.hero__stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
}
.hero__stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
}
.hero__stat-divider {
  color: var(--gold);
  font-size: 0.5rem;
  opacity: 0.6;
}

/* ── Divider ─────────────────────────────────────────────────────────────── */
.divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 0 0 2.5rem;
}
.divider__line {
  flex: 1;
  height: 1px;
  background: var(--rule);
}
.divider__ornament {
  font-family: 'EB Garamond', serif;
  font-size: 0.9rem;
  color: var(--ink-muted);
  white-space: nowrap;
  letter-spacing: 0.15em;
}

/* ── Filter Panel ────────────────────────────────────────────────────────── */
.filter-panel {
  background: var(--paper);
  border: 1px solid var(--border);
  border-top: 3px solid var(--navy);
  padding: 1.5rem 2rem;
  margin-bottom: 2.5rem;
  box-shadow: 0 2px 8px var(--shadow);
}
.filter-panel__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
  padding-bottom: 0.875rem;
  border-bottom: 1px solid var(--rule);
}
.filter-panel__title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--navy);
  letter-spacing: 0.01em;
}
.results-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--ink-muted);
  text-transform: uppercase;
}
.filter-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.filter-group {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  flex-wrap: wrap;
}
.filter-label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  min-width: 5.5rem;
  padding-top: 0.4rem;
  flex-shrink: 0;
}
.filter-label__icon { color: var(--gold); font-size: 0.6rem; }

.filter-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }

.chip {
  padding: 0.3rem 0.9rem;
  border: 1px solid var(--border);
  background: var(--cream);
  font-family: 'EB Garamond', serif;
  font-size: 0.9rem;
  color: var(--ink-mid);
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.15s ease;
  line-height: 1.5;
  white-space: nowrap;
}
.chip:hover {
  border-color: var(--navy);
  color: var(--navy);
  background: var(--cream-dark);
}
.chip--active {
  background: var(--navy);
  border-color: var(--navy);
  color: var(--cream);
}
.chip--active:hover {
  background: var(--navy-mid);
  border-color: var(--navy-mid);
  color: var(--cream);
}

/* ── Grid ────────────────────────────────────────────────────────────────── */
.grid {
  display: grid;
  gap: 1.75rem;
  grid-template-columns: repeat(3, 1fr);
}

/* ── Empty state ─────────────────────────────────────────────────────────── */
.empty-state {
  text-align: center;
  color: var(--ink-muted);
  font-family: 'EB Garamond', serif;
  font-size: 1.1rem;
  font-style: italic;
  padding: 4rem 0;
  line-height: 2;
}
.empty-state__icon {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  color: var(--rule);
  font-style: normal;
  display: block;
}

/* ── Search bar ──────────────────────────────────────────────────────────── */
.search-wrap {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 1.25rem;
}
.search-icon {
  position: absolute;
  left: 0.85rem;
  font-size: 1.15rem;
  color: var(--ink-muted);
  pointer-events: none;
  line-height: 1;
  top: 50%;
  transform: translateY(-50%);
}
.search-input {
  width: 100%;
  padding: 0.65rem 2.5rem 0.65rem 2.4rem;
  border: 1px solid var(--border);
  border-bottom: 2px solid var(--navy);
  background: var(--cream);
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: var(--ink);
  border-radius: 2px;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  -webkit-appearance: none;
}
.search-input::placeholder {
  color: var(--ink-muted);
  font-style: italic;
}
.search-input:focus {
  border-color: var(--gold);
  border-bottom-color: var(--gold);
  box-shadow: 0 2px 0 0 var(--gold);
  background: var(--paper);
}
/* hide browser's native clear button */
.search-input::-webkit-search-cancel-button { display: none; }
.search-clear {
  position: absolute;
  right: 0.7rem;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-muted);
  font-size: 0.75rem;
  width: 1.4rem;
  height: 1.4rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.15s ease, color 0.15s ease;
  padding: 0;
}
.search-clear:hover {
  background: var(--cream-dark);
  color: var(--navy);
}

/* ── Select dropdowns (hidden on desktop, shown on mobile) ───────────────── */
.filter-select-wrap {
  display: none; /* hidden by default — shown only on mobile via media query */
  position: relative;
  width: 100%;
}
.filter-select {
  width: 100%;
  appearance: none;
  -webkit-appearance: none;
  padding: 0.6rem 2.5rem 0.6rem 0.9rem;
  border: 1px solid var(--border);
  border-bottom: 2px solid var(--navy);
  background: var(--cream);
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: var(--ink);
  border-radius: 2px;
  cursor: pointer;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  line-height: 1.5;
}
.filter-select:focus {
  border-color: var(--gold);
  border-bottom-color: var(--gold);
  box-shadow: 0 2px 0 0 var(--gold);
  background: var(--paper);
}
.filter-select__arrow {
  position: absolute;
  right: 0.85rem;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  color: var(--navy);
  font-size: 0.75rem;
  line-height: 1;
}

/* ── Messenger CTA ───────────────────────────────────────────────────────── */
.contact-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
  background: var(--paper);
  border: 1px solid var(--border);
  border-top: 3px solid var(--navy);
  padding: 2rem 2.5rem;
  box-shadow: 0 2px 12px var(--shadow);
  margin-top: 1rem;
}
.contact-cta__eyebrow {
  display: block;
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.4rem;
}
.contact-cta__desc {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: var(--ink-mid);
  margin: 0;
  line-height: 1.5;
}
.contact-cta__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.75rem 1.75rem;
  background: #0084ff;
  color: #fff;
  border-radius: 4px;
  text-decoration: none;
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 500;
  white-space: nowrap;
  transition: background 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
  box-shadow: 0 2px 10px rgba(0,132,255,0.3);
  flex-shrink: 0;
}
.contact-cta__btn:hover {
  background: #006edb;
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,132,255,0.35);
}
.contact-cta__btn:active { transform: translateY(0); }
.contact-cta__btn-icon {
  width: 1.1rem;
  height: 1.1rem;
  flex-shrink: 0;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
  .hero { padding: 2rem 0.5rem 1.5rem; }
  .hero__stats { padding: 0.75rem 1.25rem; gap: 1rem; }
  .filter-panel { padding: 1.25rem 1rem; }
  .filter-group { flex-direction: column; gap: 0.5rem; }
  .filter-label { min-width: unset; padding-top: 0; }

  /* On mobile: hide chips, show select dropdowns */
  .filter-chips { display: none; }
  .filter-select-wrap { display: block; }

  .grid { grid-template-columns: 1fr; gap: 1.25rem; }

  .contact-cta {
    flex-direction: column;
    align-items: flex-start;
    padding: 1.5rem 1.25rem;
  }
  .contact-cta__btn {
    width: 100%;
    justify-content: center;
  }
}
</style>

<script>
const TEAM = [
    { name: "NIUGEN MARC D. PAGALA", role: "", img: "/pagala.png" },
    { name: "SOPHIA NOREENE A. ZAMORA", role: "", img: "/Zamora.png" },
    { name: "CYNTHIA GIGANTE SANTEAÑEZ", role: "", img: "/Santeañez.png" },
     { name: "TRIXIE MAE S. LACDAO", role: "", img: "/lacdao.png" }
  ];
  const PAL = [
    ["#0f1f3d","#d4a843"],["#1a3360","#e8d5a3"],["#2a4a7f","#faf8f3"],
    ["#1e3a5f","#c9a84c"],["#0d2137","#f0e0b0"],["#162d4a","#d4a843"],
  ];
  function ini(n){ return n.trim().split(/\s+/).map(w=>w[0]||"").join("").toUpperCase().slice(0,2)||"?"; }
  function pal(i){ const idx=((i.charCodeAt(0)||0)+(i.charCodeAt(1)||0))%PAL.length; return PAL[idx]; }
  function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }

  const grid = document.getElementById("team-grid");
  TEAM.forEach(function(m,i){
    const initials = ini(m.name);
    const colors = pal(initials);
    const card = document.createElement("div");
    card.className = "team-card";
    card.style.animationDelay = (i*0.07)+"s";
    const av = m.img
      ? '<img class="team-card__img" src="'+esc(m.img)+'" alt="'+esc(m.name)+'" loading="lazy" />'
      : '<div class="team-card__initials" style="background:'+colors[0]+';color:'+colors[1]+';">'+esc(initials)+'</div>';
    card.innerHTML =
      '<div class="team-card__avatar-wrap">'+av+'</div>'+
      '<div class="team-card__info">'+
        '<span class="team-card__name">'+esc(m.name)+'</span>'+
        '<span class="team-card__role">'+esc(m.role)+'</span>'+
      '</div>';
    grid.appendChild(card);
  });

  const modal    = document.getElementById("team-modal");
  const openBtn  = document.getElementById("open-team-modal");
  const closeBtn = document.getElementById("close-team-modal");
  function openModal(){
    modal.style.display="flex";
    document.body.style.overflow="hidden";
    setTimeout(function(){ modal.classList.add("team-modal-overlay--in"); },10);
    closeBtn.focus();
  }
  function closeModal(){
    modal.classList.remove("team-modal-overlay--in");
    setTimeout(function(){ modal.style.display="none"; document.body.style.overflow=""; },280);
  }
  openBtn.addEventListener("click", openModal);
  closeBtn.addEventListener("click", closeModal);
  modal.addEventListener("click", function(e){ if(e.target===modal) closeModal(); });
  document.addEventListener("keydown", function(e){ if(e.key==="Escape") closeModal(); });
</script>

