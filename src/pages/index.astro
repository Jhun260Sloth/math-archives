---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArchiveCard from "../components/ArchiveCard.astro";
import { archives, categories, years } from "../data/archives.js";
---
<BaseLayout title="Mathematics Archive · BSEd">

  <!-- ── Hero header ──────────────────────────────────────────────────── -->
  <header class="hero">
    <div class="hero__eyebrow">
      <span class="hero__rule-line"></span>
      <span class="hero__eyebrow-text">Bachelor of Secondary Education</span>
      <span class="hero__rule-line"></span>
    </div>
    <h1 class="hero__title">Mathematics<br /><em>Archive Project</em></h1>
    <p class="hero__sub">
      A curated repository of academic resources, reference materials, and pedagogical guides
      spanning the full four-year BSEd Mathematics curriculum.
    </p>
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-num">{archives.length}</span>
        <span class="hero__stat-label">Resources</span>
      </div>
      <div class="hero__stat-divider">◆</div>
      <div class="hero__stat">
        <span class="hero__stat-num">4</span>
        <span class="hero__stat-label">Year Levels</span>
      </div>
      <div class="hero__stat-divider">◆</div>
      <div class="hero__stat">
        <span class="hero__stat-num">4</span>
        <span class="hero__stat-label">Disciplines</span>
      </div>
    </div>
  </header>

  <!-- ── Ornamental divider ────────────────────────────────────────────── -->
  <div class="divider" aria-hidden="true">
    <span class="divider__line"></span>
    <span class="divider__ornament">— § —</span>
    <span class="divider__line"></span>
  </div>

  <!-- ── Filter panel ──────────────────────────────────────────────────── -->
  <section class="filter-panel" aria-label="Filter resources">
    <div class="filter-panel__header">
      <h2 class="filter-panel__title">Browse the Collection</h2>
      <span class="results-count" id="results-count">{archives.length} entries</span>
    </div>

    <div class="filter-grid">
      <div class="filter-group">
        <span class="filter-label">
          <span class="filter-label__icon">◈</span>
          Year Level
        </span>
        <div class="filter-chips" id="year-filters">
          {years.map((y) => (
            <button
              class={`chip${y.id === "all" ? " chip--active" : ""}`}
              data-filter-year={y.id}
            >
              {y.label}
            </button>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <span class="filter-label">
          <span class="filter-label__icon">◈</span>
          Discipline
        </span>
        <div class="filter-chips" id="category-filters">
          {categories.map((c) => (
            <button
              class={`chip${c.id === "all" ? " chip--active" : ""}`}
              data-filter-cat={c.id}
            >
              {c.label}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Card grid ─────────────────────────────────────────────────────── -->
  <section class="grid" id="archive-grid" aria-label="Archive entries">
    {archives.map((item) => (
      <div class="card-wrapper" data-year={item.year} data-category={item.category}>
        <ArchiveCard {...item} />
      </div>
    ))}
  </section>

  <p class="empty-state" id="empty-state" style="display:none;">
    <span class="empty-state__icon">∅</span><br />
    No entries found for the selected filters.
  </p>

</BaseLayout>

<script>
  const yearBtns = document.querySelectorAll("[data-filter-year]");
  const catBtns  = document.querySelectorAll("[data-filter-cat]");
  const allCards = Array.from(document.querySelectorAll(".card-wrapper"));
  const countEl  = document.getElementById("results-count");
  const emptyEl  = document.getElementById("empty-state");

  let activeYear = "all";
  let activeCat  = "all";

  function applyFilters() {
    let visible = 0;
    allCards.forEach((c) => {
      const show = (activeYear === "all" || c.dataset.year === activeYear)
                && (activeCat  === "all" || c.dataset.category === activeCat);
      c.style.display = show ? "" : "none";
      if (show) visible++;
    });
    countEl.textContent = `${visible} entr${visible !== 1 ? "ies" : "y"}`;
    emptyEl.style.display = visible === 0 ? "block" : "none";
  }

  yearBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      yearBtns.forEach((b) => b.classList.remove("chip--active"));
      btn.classList.add("chip--active");
      activeYear = btn.dataset.filterYear;
      applyFilters();
    });
  });

  catBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      catBtns.forEach((b) => b.classList.remove("chip--active"));
      btn.classList.add("chip--active");
      activeCat = btn.dataset.filterCat;
      applyFilters();
    });
  });

  applyFilters();
</script>

<style>
/* ── Hero ────────────────────────────────────────────────────────────────── */
.hero {
  text-align: center;
  padding: 3rem 1rem 2.5rem;
  max-width: 760px;
  margin: 0 auto 2rem;
}
.hero__eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.hero__rule-line {
  flex: 1;
  max-width: 80px;
  height: 1px;
  background: var(--gold);
  opacity: 0.5;
}
.hero__eyebrow-text {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
}
.hero__title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 700;
  color: var(--navy);
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -0.01em;
}
.hero__title em {
  font-style: italic;
  color: var(--gold);
}
.hero__sub {
  font-family: 'EB Garamond', serif;
  font-size: 1.1rem;
  color: var(--ink-mid);
  line-height: 1.75;
  max-width: 560px;
  margin: 0 auto 2rem;
}
.hero__stats {
  display: inline-flex;
  align-items: center;
  gap: 1.5rem;
  border: 1px solid var(--border);
  background: var(--paper);
  padding: 0.9rem 2.5rem;
  border-top: 2px solid var(--gold);
  box-shadow: 0 2px 12px var(--shadow);
  flex-wrap: wrap;
  justify-content: center;
}
.hero__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.1rem;
}
.hero__stat-num {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
}
.hero__stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
}
.hero__stat-divider {
  color: var(--gold);
  font-size: 0.5rem;
  opacity: 0.6;
}

/* ── Divider ─────────────────────────────────────────────────────────────── */
.divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 0 0 2.5rem;
}
.divider__line {
  flex: 1;
  height: 1px;
  background: var(--rule);
}
.divider__ornament {
  font-family: 'EB Garamond', serif;
  font-size: 0.9rem;
  color: var(--ink-muted);
  white-space: nowrap;
  letter-spacing: 0.15em;
}

/* ── Filter Panel ────────────────────────────────────────────────────────── */
.filter-panel {
  background: var(--paper);
  border: 1px solid var(--border);
  border-top: 3px solid var(--navy);
  padding: 1.5rem 2rem;
  margin-bottom: 2.5rem;
  box-shadow: 0 2px 8px var(--shadow);
}
.filter-panel__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
  padding-bottom: 0.875rem;
  border-bottom: 1px solid var(--rule);
}
.filter-panel__title {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--navy);
  letter-spacing: 0.01em;
}
.results-count {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--ink-muted);
  text-transform: uppercase;
}
.filter-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.filter-group {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  flex-wrap: wrap;
}
.filter-label {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  min-width: 5.5rem;
  padding-top: 0.4rem;
  flex-shrink: 0;
}
.filter-label__icon { color: var(--gold); font-size: 0.6rem; }

.filter-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }

.chip {
  padding: 0.3rem 0.9rem;
  border: 1px solid var(--border);
  background: var(--cream);
  font-family: 'EB Garamond', serif;
  font-size: 0.9rem;
  color: var(--ink-mid);
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.15s ease;
  line-height: 1.5;
  white-space: nowrap;
}
.chip:hover {
  border-color: var(--navy);
  color: var(--navy);
  background: var(--cream-dark);
}
.chip--active {
  background: var(--navy);
  border-color: var(--navy);
  color: var(--cream);
}
.chip--active:hover {
  background: var(--navy-mid);
  border-color: var(--navy-mid);
  color: var(--cream);
}

/* ── Grid ────────────────────────────────────────────────────────────────── */
.grid {
  display: grid;
  gap: 1.75rem;
  grid-template-columns: repeat(3, 1fr);
}

/* ── Empty state ─────────────────────────────────────────────────────────── */
.empty-state {
  text-align: center;
  color: var(--ink-muted);
  font-family: 'EB Garamond', serif;
  font-size: 1.1rem;
  font-style: italic;
  padding: 4rem 0;
  line-height: 2;
}
.empty-state__icon {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  color: var(--rule);
  font-style: normal;
  display: block;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
  .hero { padding: 2rem 0.5rem 1.5rem; }
  .hero__stats { padding: 0.75rem 1.25rem; gap: 1rem; }
  .filter-panel { padding: 1.25rem 1rem; }
  .filter-group { flex-direction: column; gap: 0.5rem; }
  .filter-label { min-width: unset; padding-top: 0; }
  .chip { font-size: 0.85rem; }
  .grid { grid-template-columns: 1fr; gap: 1.25rem; }
}
</style>