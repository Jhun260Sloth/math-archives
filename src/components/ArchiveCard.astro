---
const { title, description, url, image, category, year } = Astro.props;
const imgSrc = image && image.trim() !== "" ? image : null;

const categoryLabels = {
  pure:       "Pure Mathematics",
  applied:    "Applied Mathematics",
  education:  "Mathematics Education",
  supporting: "Supporting Courses",
};
const yearLabels = {
  "1": "Year I",
  "2": "Year II",
  "3": "Year III",
  "4": "Year IV",
};
const categoryColors = {
  pure:       "tag--pure",
  applied:    "tag--applied",
  education:  "tag--education",
  supporting: "tag--supporting",
};
---

<article class="card">
  <a href={url} target="_blank" rel="noopener noreferrer" class="card__link">

    <!-- Image or placeholder -->
    <div class="card__media">
      {imgSrc ? (
        <img src={imgSrc} alt={title} loading="lazy" decoding="async" class="card__img" />
      ) : (
        <div class="card__placeholder" aria-hidden="true">
          <span class="card__placeholder-symbol">∑</span>
        </div>
      )}
      <!-- Year badge -->
      <span class="card__year-badge">{yearLabels[year] ?? `Year ${year}`}</span>
    </div>

    <!-- Content -->
    <div class="card__body">
      <div class="card__meta">
        <span class={`card__tag ${categoryColors[category] ?? ""}`}>
          {categoryLabels[category] ?? category}
        </span>
      </div>

      <h3 class="card__title">{title}</h3>
      <div class="card__rule"></div>
      <p class="card__desc">{description}</p>

      <span class="card__cta">
        {url === "#" ? (
          <span class="card__cta-text card__cta--soon">Coming soon</span>
        ) : (
          <span class="card__cta-text">Open resource <span class="card__arrow">→</span></span>
        )}
      </span>
    </div>

  </a>
</article>

<style>
.card {
  background: var(--paper);
  border: 1px solid var(--border);
  border-top: 3px solid var(--navy);
  border-radius: 2px;
  overflow: hidden;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-top-color 0.22s ease;
  box-shadow: 0 2px 8px var(--shadow), 0 0 0 0 transparent;
  display: flex;
  flex-direction: column;
}
.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 32px rgba(15,31,61,0.13);
  border-top-color: var(--gold);
}
.card__link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* Media */
.card__media {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--navy);
}
.card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease, opacity 0.3s ease;
  opacity: 0.92;
}
.card:hover .card__img {
  transform: scale(1.04);
  opacity: 1;
}
.card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-soft) 100%);
}
.card__placeholder-symbol {
  font-family: 'Playfair Display', serif;
  font-size: 3.5rem;
  color: rgba(212, 168, 67, 0.25);
  user-select: none;
}

/* Year badge */
.card__year-badge {
  position: absolute;
  top: 0.65rem;
  right: 0.65rem;
  background: var(--navy);
  color: var(--gold-light);
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2rem 0.55rem;
  border: 1px solid rgba(212,168,67,0.35);
  border-radius: 2px;
}

/* Body */
.card__body {
  padding: 1.4rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* Category tag */
.card__meta { margin-bottom: 0.75rem; }
.card__tag {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 0.63rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.18rem 0.6rem;
  border-radius: 2px;
  border: 1px solid currentColor;
  font-weight: 500;
}
.tag--pure       { color: #1a5276; border-color: rgba(26,82,118,0.35); background: rgba(26,82,118,0.06); }
.tag--applied    { color: #1e6a3e; border-color: rgba(30,106,62,0.35); background: rgba(30,106,62,0.06); }
.tag--education  { color: #7d3c00; border-color: rgba(125,60,0,0.35);  background: rgba(125,60,0,0.06);  }
.tag--supporting { color: #5b2d8e; border-color: rgba(91,45,142,0.35); background: rgba(91,45,142,0.06); }

/* Title */
.card__title {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.35;
  margin-bottom: 0.6rem;
}

/* Rule */
.card__rule {
  width: 2rem;
  height: 1px;
  background: var(--gold);
  opacity: 0.5;
  margin-bottom: 0.65rem;
  transition: width 0.3s ease;
}
.card:hover .card__rule { width: 3.5rem; opacity: 0.85; }

/* Description */
.card__desc {
  font-family: 'EB Garamond', serif;
  font-size: 0.95rem;
  color: var(--ink-mid);
  line-height: 1.6;
  flex: 1;
  margin-bottom: 1.2rem;
}

/* CTA */
.card__cta { margin-top: auto; }
.card__cta-text {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--navy-soft);
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  transition: color 0.2s ease;
}
.card:hover .card__cta-text { color: var(--gold); }
.card__cta--soon { color: var(--ink-muted) !important; font-style: italic; }
.card__arrow { transition: transform 0.2s ease; display: inline-block; }
.card:hover .card__arrow { transform: translateX(4px); }
</style>